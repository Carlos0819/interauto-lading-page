---
const title = "Página no encontrada | INTERAUTO SAVV";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Roboto:wght@400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Roboto', sans-serif;
        background: #1a1a1a;
        color: white;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
      }
      .code {
        font-family: 'Montserrat', sans-serif;
        font-weight: 900;
        font-size: clamp(5rem, 15vw, 10rem);
        line-height: 1;
        color: #DA251D;
      }
      .msg {
        color: rgba(255,255,255,0.4);
        font-size: 1rem;
        margin: 1rem 0 2.5rem;
      }
      a {
        display: inline-block;
        background: white;
        color: #1a1a1a;
        text-decoration: none;
        padding: 0.75rem 2rem;
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: background 0.2s;
      }
      a:hover { background: rgba(255,255,255,0.9); }
      .logo { height: 2.5rem; margin-bottom: 2rem; opacity: 0.6; }
    </style>
  </head>
  <body>
    <div>
      <img src="/logo.png" alt="INTERAUTO SAVV" class="logo" />
      <div class="code">404</div>
      <p class="msg">La página que buscas no existe o fue movida.</p>
      <a href="/">Volver al inicio</a>
    </div>
  </body>
</html>
