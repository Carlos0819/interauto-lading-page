---
import { vehicles } from "../data/vehicles";
---

<div id="vehicle-modal" class="modal-backdrop fixed inset-0 z-[100] bg-black/60 backdrop-blur-sm flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-label="Detalle del vehículo">
  <div class="modal-content bg-white rounded-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto shadow-2xl" style="-ms-overflow-style:none;scrollbar-width:none;">
    <!-- Header Image -->
    <div class="relative h-64 sm:h-80 overflow-hidden rounded-t-2xl bg-[#e8e8e8]">
      <img id="modal-image" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="" class="w-full h-full object-cover transition-opacity duration-300" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

      <button id="modal-close" class="absolute top-4 right-4 w-10 h-10 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center hover:bg-white transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-red-primary" aria-label="Cerrar">
        <svg class="w-5 h-5 text-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="absolute bottom-6 left-6 right-6">
        <span id="modal-category" class="inline-block px-3 py-1 bg-red-primary text-white text-xs font-bold uppercase tracking-wider mb-3"></span>
        <h2 id="modal-title" class="font-heading font-[900] text-2xl sm:text-3xl text-white"></h2>
      </div>
    </div>

    <!-- Body -->
    <div class="p-6 sm:p-8">
      <p id="modal-description" class="text-dark/60 text-base leading-relaxed mb-8"></p>

      <!-- Specs -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
        <div class="bg-[#fafafa] rounded-lg p-4 text-center">
          <p class="text-[10px] text-dark/35 uppercase tracking-wider font-medium">Motor</p>
          <p id="modal-motor" class="font-heading font-bold text-sm text-dark mt-1"></p>
        </div>
        <div class="bg-[#fafafa] rounded-lg p-4 text-center">
          <p class="text-[10px] text-dark/35 uppercase tracking-wider font-medium">Potencia</p>
          <p id="modal-potencia" class="font-heading font-bold text-sm text-dark mt-1"></p>
        </div>
        <div class="bg-[#fafafa] rounded-lg p-4 text-center">
          <p class="text-[10px] text-dark/35 uppercase tracking-wider font-medium">Transmisión</p>
          <p id="modal-transmision" class="font-heading font-bold text-sm text-dark mt-1"></p>
        </div>
        <div class="bg-[#fafafa] rounded-lg p-4 text-center">
          <p class="text-[10px] text-dark/35 uppercase tracking-wider font-medium">Combustible</p>
          <p id="modal-combustible" class="font-heading font-bold text-sm text-dark mt-1"></p>
        </div>
        <div class="bg-[#fafafa] rounded-lg p-4 text-center col-span-2 sm:col-span-1">
          <p class="text-[10px] text-dark/35 uppercase tracking-wider font-medium">Pasajeros</p>
          <p id="modal-pasajeros" class="font-heading font-bold text-sm text-dark mt-1"></p>
        </div>
      </div>

      <!-- Features -->
      <ul id="modal-features" class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-8"></ul>

      <!-- CTA -->
      <button id="modal-cta" class="block w-full text-center bg-red-primary hover:bg-red-dark text-white py-4 font-heading font-bold uppercase text-sm tracking-wider transition-colors focus:outline-none focus:ring-2 focus:ring-red-primary focus:ring-offset-2 cursor-pointer rounded-lg">
        Solicitar Cotización
      </button>
    </div>
  </div>
</div>

<script define:vars={{ vehiclesData: JSON.stringify(vehicles) }}>
  const vehicles = JSON.parse(vehiclesData);
  const modal = document.getElementById("vehicle-modal");
  const closeBtn = document.getElementById("modal-close");

  function openModal(vehicleId) {
    const v = vehicles.find((v) => v.id === vehicleId);
    if (!v) return;

    const img = document.getElementById("modal-image");
    img.style.opacity = "0";
    img.src = v.image;
    img.alt = `${v.brand} ${v.model}`;
    img.onload = () => { img.style.opacity = "1"; };

    document.getElementById("modal-category").textContent = v.category;
    document.getElementById("modal-title").textContent = `${v.brand} ${v.model}`;
    document.getElementById("modal-description").textContent = v.description;
    document.getElementById("modal-motor").textContent = v.specs.motor;
    document.getElementById("modal-potencia").textContent = v.specs.potencia;
    document.getElementById("modal-transmision").textContent = v.specs.transmision;
    document.getElementById("modal-combustible").textContent = v.specs.combustible;
    document.getElementById("modal-pasajeros").textContent = v.specs.pasajeros.toString();

    document.getElementById("modal-features").innerHTML = v.features
      .map((f) =>
        `<li class="flex items-start gap-2 text-sm text-dark/60">
          <svg class="w-4 h-4 text-red-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          ${f}
        </li>`
      ).join("");

    modal.classList.add("active");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.remove("active");
    document.body.style.overflow = "";
  }

  let currentVehicleId = "";

  closeBtn.addEventListener("click", closeModal);

  // CTA opens quote modal with current vehicle pre-selected
  document.getElementById("modal-cta").addEventListener("click", () => {
    closeModal();
    setTimeout(() => window.openQuoteModal(currentVehicleId), 350);
  });

  modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal.classList.contains("active")) closeModal();
  });
  document.addEventListener("click", (e) => {
    const card = e.target.closest(".vehicle-card");
    if (card && !e.target.closest("[data-quote]")) {
      currentVehicleId = card.dataset.vehicleId;
      openModal(currentVehicleId);
    }
  });
</script>
