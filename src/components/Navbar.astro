---
const navLinks = [
  { label: "Nosotros", href: "#quienes-somos" },
  { label: "Modelos", href: "#catalogo" },
  { label: "Marcas", href: "#marcas" },
  { label: "Contacto", href: "#contacto" },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg transition-all duration-500">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-16">
      <a href="#inicio">
        <img src="/logo.png" alt="INTERAUTO SAVV" class="h-9 w-auto" />
      </a>

      <ul class="hidden lg:flex items-center gap-10">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-dark/80 hover:text-dark text-[13px] font-medium tracking-wide transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col gap-[5px] p-2 cursor-pointer"
        aria-label="Menu"
      >
        <span class="block w-5 h-[1.5px] bg-dark transition-all duration-300 origin-center" id="bar1"></span>
        <span class="block w-5 h-[1.5px] bg-dark transition-all duration-300" id="bar2"></span>
        <span class="block w-5 h-[1.5px] bg-dark transition-all duration-300 origin-center" id="bar3"></span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden max-h-0 overflow-hidden transition-all duration-500 ease-in-out bg-white/95 backdrop-blur-lg"
  >
    <ul class="px-6 py-6 space-y-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link block py-3 text-dark/70 hover:text-dark text-sm font-medium transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;
  let isOpen = false;

  btn.addEventListener("click", () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu.style.maxHeight = menu.scrollHeight + "px";
      bar1.style.transform = "rotate(45deg) translate(3px, 3px)";
      bar2.style.opacity = "0";
      bar3.style.transform = "rotate(-45deg) translate(3px, -3px)";
    } else {
      menu.style.maxHeight = "0";
      bar1.style.transform = "";
      bar2.style.opacity = "1";
      bar3.style.transform = "";
    }
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      menu.style.maxHeight = "0";
      bar1.style.transform = "";
      bar2.style.opacity = "1";
      bar3.style.transform = "";
    });
  });

  const navbar = document.getElementById("navbar")!;
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar.classList.add("shadow-[0_1px_0_rgba(0,0,0,0.08)]");
    } else {
      navbar.classList.remove("shadow-[0_1px_0_rgba(0,0,0,0.08)]");
    }
  });
</script>
