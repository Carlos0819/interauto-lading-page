---
const navLinks = [
  { label: "Nosotros", href: "#quienes-somos" },
  { label: "Modelos", href: "#catalogo" },
  { label: "Marcas", href: "#marcas" },
  { label: "Contacto", href: "#contacto" },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 nav-transparent">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-18">
      <a href="#inicio">
        <img src="/logo.png" alt="INTERAUTO SAVV" class="h-9 w-auto nav-logo transition-all duration-300" />
      </a>

      <ul class="hidden lg:flex items-center gap-10">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link text-[13px] font-medium tracking-wide transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <button
            data-quote=""
            class="bg-red-primary text-white px-5 py-2 text-[12px] font-bold uppercase tracking-wider hover:bg-red-dark transition-colors duration-200 cursor-pointer"
          >
            Cotización
          </button>
        </li>
      </ul>

      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col gap-[5px] p-2 cursor-pointer"
        aria-label="Menu"
      >
        <span class="block w-5 h-[1.5px] bg-current transition-all duration-300 origin-center" id="bar1"></span>
        <span class="block w-5 h-[1.5px] bg-current transition-all duration-300" id="bar2"></span>
        <span class="block w-5 h-[1.5px] bg-current transition-all duration-300 origin-center" id="bar3"></span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden max-h-0 overflow-hidden transition-all duration-500 ease-in-out"
  >
    <ul class="px-6 py-6 space-y-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link block py-3 text-sm font-medium transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-3">
        <button data-quote="" class="mobile-link block w-full text-center bg-red-primary text-white py-3 text-sm font-bold uppercase tracking-wider cursor-pointer">
          Solicitar Cotización
        </button>
      </li>
    </ul>
  </div>
</nav>

<style>
  /* Transparent state (over hero) */
  .nav-transparent {
    background: transparent;
  }
  .nav-transparent .nav-link {
    color: rgba(255,255,255,0.8);
  }
  .nav-transparent .nav-link:hover {
    color: #fff;
  }
  .nav-transparent .mobile-link {
    color: rgba(255,255,255,0.7);
  }
  .nav-transparent .mobile-link:hover {
    color: #fff;
  }
  .nav-transparent #mobile-menu {
    background: rgba(0,0,0,0.9);
    backdrop-filter: blur(20px);
  }
  .nav-transparent #mobile-menu-btn {
    color: white;
  }
  .nav-transparent .nav-logo {
    filter: brightness(0) invert(1);
  }

  /* Solid state (scrolled) */
  .nav-solid {
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(0,0,0,0.06);
  }
  .nav-solid .nav-link {
    color: rgba(26,26,26,0.7);
  }
  .nav-solid .nav-link:hover {
    color: #1a1a1a;
  }
  .nav-solid .mobile-link {
    color: rgba(26,26,26,0.7);
  }
  .nav-solid .mobile-link:hover {
    color: #1a1a1a;
  }
  .nav-solid #mobile-menu {
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(20px);
  }
  .nav-solid #mobile-menu-btn {
    color: #1a1a1a;
  }
  .nav-solid .nav-logo {
    filter: none;
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;
  let isOpen = false;

  btn.addEventListener("click", () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu.style.maxHeight = menu.scrollHeight + "px";
      bar1.style.transform = "rotate(45deg) translate(3px, 3px)";
      bar2.style.opacity = "0";
      bar3.style.transform = "rotate(-45deg) translate(3px, -3px)";
    } else {
      menu.style.maxHeight = "0";
      bar1.style.transform = "";
      bar2.style.opacity = "1";
      bar3.style.transform = "";
    }
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      menu.style.maxHeight = "0";
      bar1.style.transform = "";
      bar2.style.opacity = "1";
      bar3.style.transform = "";
    });
  });

  const navbar = document.getElementById("navbar")!;
  window.addEventListener("scroll", () => {
    if (window.scrollY > 80) {
      navbar.classList.remove("nav-transparent");
      navbar.classList.add("nav-solid");
    } else {
      navbar.classList.remove("nav-solid");
      navbar.classList.add("nav-transparent");
    }
  });
</script>
