---
const cities = [
  { name: "La Paz", role: "Oficina Principal" },
  { name: "Cochabamba", role: "Sucursal Regional" },
  { name: "Santa Cruz", role: "Sucursal Regional" },
];
---

<section id="presencia" class="py-20 sm:py-28 bg-dark relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-red-primary/5 rounded-full blur-[120px]"></div>

  <div class="max-w-[900px] mx-auto px-6 relative z-10">
    <div class="animate-on-scroll text-center mb-14">
      <p class="text-red-primary text-xs font-bold uppercase tracking-[0.3em] mb-4">Cobertura Nacional</p>
      <h2 class="font-heading font-[900] text-3xl sm:text-5xl text-white leading-tight">
        Presentes en todo
        <span class="text-red-primary">Bolivia</span>
      </h2>
    </div>

    <div class="animate-on-scroll delay-1 flex flex-col sm:flex-row items-stretch justify-center">
      {cities.map((city, i) => (
        <div class={`flex-1 text-center py-8 px-6 ${i < cities.length - 1 ? 'sm:border-r sm:border-white/10' : ''}`}>
          <h3 class="font-heading font-[800] text-xl sm:text-2xl text-white mb-1">
            {city.name}
          </h3>
          <p class="text-white/25 text-xs font-medium uppercase tracking-wider">{city.role}</p>
        </div>
      ))}
    </div>

    <div class="animate-on-scroll delay-2 mt-12 text-center">
      <p class="text-white/15 text-sm max-w-lg mx-auto leading-relaxed">
        Consolidando presencia en el mercado boliviano, generando valor para clientes, aliados estratégicos e instituciones financieras.
      </p>
    </div>
  </div>
</section>
