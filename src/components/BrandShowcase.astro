---
const brands = [
  { name: "TOYOTA", logo: "/toyota.svg", category: "SUV · Pickup · Utilitario" },
  { name: "JETOUR", logo: "/jetour.png", category: "SUV" },
  { name: "MAXUS", logo: "/maxus.png", category: "Utilitario · Eléctrico" },
  { name: "BYD", logo: "/byd.png", category: "Eléctrico · Híbrido" },
  { name: "SOUEAST", logo: "/soueast.webp", category: "SUV" },
  { name: "YADEA", logo: "/yadea.png", category: "Movilidad Eléctrica" },
];
const allBrands = [...brands, ...brands];
---

<section id="marcas" class="py-24 sm:py-32 bg-white overflow-hidden border-t border-dark/5">
  <div class="max-w-[1100px] mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="font-heading font-[800] text-3xl sm:text-4xl text-dark">Marcas Representadas</h2>
      <div class="w-12 h-[2px] bg-red-primary mx-auto mt-4"></div>
    </div>
  </div>

  <!-- Carousel -->
  <div id="brand-carousel" class="relative animate-on-scroll delay-1">
    <div id="brand-track" class="flex w-max animate-scroll-brands">
      {allBrands.map((brand) => (
        <div class="brand-slide flex-shrink-0 w-[220px] sm:w-[280px] px-8 flex flex-col items-center text-center cursor-default group">
          <div class="h-28 sm:h-32 flex items-center justify-center mb-5">
            <img
              src={brand.logo}
              alt={brand.name}
              class="max-h-full max-w-[170px] sm:max-w-[200px] object-contain transition-transform duration-300 group-hover:scale-110"
              loading="lazy"
            />
          </div>
          <h3 class="font-heading font-[800] text-base sm:text-lg text-dark tracking-wider mb-1">
            {brand.name}
          </h3>
          <p class="text-dark/40 text-xs sm:text-sm">{brand.category}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes scroll-brands {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-scroll-brands {
    animation: scroll-brands 22s linear infinite;
  }

  #brand-carousel:hover .animate-scroll-brands {
    animation-play-state: paused;
  }
</style>
