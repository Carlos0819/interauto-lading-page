---
const brands = [
  { name: "TOYOTA", logo: "/toyota.svg", category: "SUV · Pickup · Utilitario" },
  { name: "JETOUR", logo: "/jetour.png", category: "SUV" },
  { name: "MAXUS", logo: "/maxus.png", category: "SUV · Utilitario" },
  { name: "BYD", logo: "/byd.png", category: "Híbrido Plug-in" },
  { name: "SOUEAST", logo: "/soueast.webp", category: "SUV" },
  { name: "YADEA", logo: "/yadea.png", category: "Movilidad Eléctrica" },
];
const allBrands = [...brands, ...brands];
---

<section id="marcas" class="py-24 sm:py-32 bg-white overflow-hidden relative">
  <div class="max-w-[1100px] mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
      <p class="text-red-primary text-xs font-bold uppercase tracking-[0.3em] mb-4">Partners Oficiales</p>
      <h2 class="font-heading font-[800] text-3xl sm:text-4xl text-dark">Marcas Representadas</h2>
    </div>
  </div>

  <!-- Carousel -->
  <div id="brand-carousel" class="relative animate-on-scroll delay-1">
    <div id="brand-track" class="flex w-max animate-scroll-brands">
      {allBrands.map((brand) => (
        <div class="brand-slide flex-shrink-0 w-[220px] sm:w-[280px] px-8 flex flex-col items-center text-center cursor-pointer group">
          <div class="h-28 sm:h-32 w-40 sm:w-48 flex items-center justify-center mb-5">
            <img
              src={brand.logo}
              alt={brand.name}
              class="brand-logo-img max-h-[80%] max-w-[160px] sm:max-w-[180px] object-contain transition-all duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>
          <h3 class="font-heading font-[800] text-base sm:text-lg text-dark tracking-wider mb-1 transition-colors duration-300 group-hover:text-red-primary">
            {brand.name}
          </h3>
          <p class="text-dark/40 text-xs sm:text-sm">{brand.category}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Wave separator to dark section -->
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-none z-[3]">
    <svg viewBox="0 0 1200 60" preserveAspectRatio="none" class="w-full h-[40px] sm:h-[60px]">
      <path d="M0,30 C300,0 900,60 1200,30 L1200,60 L0,60 Z" fill="#1a1a1a" />
    </svg>
  </div>
</section>

<style>
  @keyframes scroll-brands {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-scroll-brands {
    animation: scroll-brands 22s linear infinite;
  }

  #brand-carousel:hover .animate-scroll-brands {
    animation-play-state: paused;
  }

  /* Neon glow on the logo shape itself */
  .brand-slide:hover .brand-logo-img {
    filter:
      drop-shadow(0 0 6px rgba(218, 37, 29, 0.6))
      drop-shadow(0 0 14px rgba(218, 37, 29, 0.35))
      drop-shadow(0 0 30px rgba(218, 37, 29, 0.15));
  }
</style>
