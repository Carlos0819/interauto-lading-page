---
const salesData = [
  { year: "2024", units: 209, income: "10.5", avgMonth: "17.4", highlight: false },
  { year: "2025", units: 126, income: "11.6", avgMonth: "10.5", highlight: false },
  { year: "T1 2026", units: 46, income: "3.4", avgMonth: "15.3", highlight: true, trend: "120% Recuperación" },
];
---

<section id="ventas" class="py-20 sm:py-28 bg-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block px-4 py-1.5 bg-red-primary/10 rounded-full text-red-primary text-sm font-semibold tracking-wider uppercase mb-4">
        Resultados
      </span>
      <h2 class="font-heading font-[900] text-3xl sm:text-4xl lg:text-5xl text-dark uppercase tracking-tight">
        Ventas <span class="text-red-primary">Históricas</span>
      </h2>
      <p class="text-mid-gray text-lg mt-4 max-w-2xl mx-auto">
        Resumen de unidades vendidas e ingresos generados por período.
      </p>
    </div>

    <!-- Sales Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {salesData.map((data, index) => (
        <div class={`animate-on-scroll delay-${index + 1} relative bg-white rounded-2xl p-8 text-center transition-all duration-500 hover:-translate-y-2 ${
          data.highlight
            ? 'ring-2 ring-red-primary shadow-xl shadow-red-primary/10 scale-[1.02]'
            : 'shadow-lg hover:shadow-xl'
        }`}>
          {data.highlight && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-red-primary text-white text-xs font-bold uppercase tracking-wider rounded-full">
              Actual
            </span>
          )}

          <h3 class="font-heading font-[800] text-xl text-dark mb-6">{data.year}</h3>

          <p class="font-heading font-[900] text-5xl text-dark mb-2">
            <span class="counter" data-target={data.units.toString()}>0</span>
          </p>
          <p class="text-mid-gray text-sm uppercase tracking-wider mb-6">unidades vendidas</p>

          <div class="bg-light rounded-xl p-4 mb-4">
            <p class="text-red-primary font-heading font-[800] text-2xl">
              USD <span class="counter" data-target={data.income.replace('.', '')} data-suffix="M">{data.income}M</span>
            </p>
            <p class="text-mid-gray text-xs uppercase tracking-wider mt-1">ingresos totales</p>
          </div>

          <p class="text-dark/60 text-sm">
            {data.avgMonth} uds/mes promedio
          </p>

          {data.trend && (
            <div class="mt-4 inline-flex items-center gap-1 px-3 py-1.5 bg-green-50 text-green-700 rounded-full text-sm font-semibold">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
              {data.trend}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
